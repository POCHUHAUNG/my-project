# Backend API base URL
VITE_API_BASE=http://localhost:3001

# LINE Login Channel ID (from LINE Developers Console > LINE Login channel)
VITE_LINE_LOGIN_CLIENT_ID=your_line_login_channel_id

# Google OAuth Client ID (from Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Facebook App ID (from developers.facebook.com > My Apps > App ID)
VITE_FACEBOOK_APP_ID=your_facebook_app_id

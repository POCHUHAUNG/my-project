# Google Service Account credentials JSON (single line, stringified)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Google Sheets spreadsheet ID (found in the sheet URL)
SPREADSHEET_ID=your_spreadsheet_id_here

# Server port (optional, defaults to 3001)
PORT=3001

# LINE Login Channel (for LINE Login OAuth on registration form)
LINE_LOGIN_CLIENT_ID=your_line_login_channel_id
LINE_LOGIN_CLIENT_SECRET=your_line_login_channel_secret

# LINE Messaging API Channel (for pre-event push notifications)
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
